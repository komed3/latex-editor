{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "lib": [ "ES2022", "DOM", "DOM.Iterable" ],
    "jsx": "react-jsx",
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "allowJs": true,
    "paths": {
      "@/*": [ "./*" ]
    }
  }
}
